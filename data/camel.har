"expanded\");\n  }\n});\n</script>\n            </div>\n            <div class=\"cell small-12 medium-5 medium-text-right\">\n              <ul class=\"menu horizontal chart_types\">\n                  <li class=\"menu-text hack pt \" data-field=\"amazon\" data-asin=\"B09QD75B95\" data-locale=\"US\">\n                    <input class=\"checkbox pt amazon \" value=\"amazon\" id=\"price_type_amazon\" type=\"checkbox\" checked=\"checked\"  data-field=\"amazon\" data-asin=\"B09QD75B95\" data-locale=\"US\">\n                    <label for=\"price_type_amazon\">\n                      <a href=\"?cpf=amazon\" class=\"pt amazon\" data-field=\"amazon\" data-asin=\"B09QD75B95\" data-locale=\"US\" title=\"Toggle the Amazon price type in the chart.\">\n                        \n                        Amazon\n                      </a>\n                    </label>\n                  </li>\n                  <li class=\"menu-text hack pt \" data-field=\"new\" data-asin=\"B09QD75B95\" data-locale=\"US\">\n                    <input class=\"checkbox pt new \" value=\"new\" id=\"price_type_new\" type=\"checkbox\"   data-field=\"new\" data-asin=\"B09QD75B95\" data-locale=\"US\">\n                    <label for=\"price_type_new\">\n                      <a href=\"?cpf=amazon-new\" class=\"pt new\" data-field=\"new\" data-asin=\"B09QD75B95\" data-locale=\"US\" title=\"Toggle the 3rd Party New price type in the chart.\">\n                        \n                        New\n                      </a>\n                    </label>\n                  </li>\n                  <li class=\"menu-text hack pt \" data-field=\"used\" data-asin=\"B09QD75B95\" data-locale=\"US\">\n                    <input class=\"checkbox pt used \" value=\"used\" id=\"price_type_used\" type=\"checkbox\"   data-field=\"used\" data-asin=\"B09QD75B95\" data-locale=\"US\">\n                    <label for=\"price_type_used\">\n                      <a href=\"?cpf=amazon-used\" class=\"pt used\" data-field=\"used\" data-asin=\"B09QD75B95\" data-locale=\"US\" title=\"Toggle the 3rd Party Used price type in the chart.\">\n                        \n                        Used\n                      </a>\n                    </label>\n                  </li>\n              </ul>\n            </div>\n            <div class=\"cell small-12\" id=\"chart_parent\">\n              <div id=\"chartplaceholder\">\n                <div class='spinner'></div>\n              </div>\n              <style>\n                #chartplaceholder\n                {\n                  display: block;\n                  background-color: #f2f2f2;\n\n                    width: 100%;\n                    height: 600px;\n                }\n\n                #summary_chart\n                {\n                  display: none;\n                }\n              </style>\n              <a href=\"https://camelcamelcamel.com/product/1BZ0P9WQSD17G5XBD905Y/go?context=product&amp;ctx_pid=192721609&amp;ctx_cid=-1&amp;ctx_aid=-1&amp;ctx_act=buy&amp;\" target=\"_blank\" title=\"View this product at Amazon\" style=\"display: block;\">\n                <img id=\"summary_chart\" alt=\"Amazon Price History Chart\">\n              </a>\n              <!--/sse-->\n            </div>\n\n            <div class=\"cell small-12\">\n              <!--sse-->\n              <div class=\"table-scroll camelegend\">\n                <table>\n                  <thead>\n                    <tr>\n                      <th class=\"fixed\">\n                        <span class=\"circle empty\"><!-- --></span>\n                        Price Type\n                      </th>\n                      <th>\n                        Lowest Ever\n                      </th>\n                      <th>\n                        Highest Ever\n                      </th>\n                      <th>\n                        Current <span data-tooltip title=\"Last checked Apr 23, 2026.\">+</span>\n                      </th>\n                      <th>\n                        Average\n                      </th>\n                    </tr>\n                  </thead>\n                  <tbody>\n                      <tr class=\"pt amazon on\" data-field=\"amazon\">\n                        <td class=\"fixed nowrap amazon\">\n                          <span class=\"circle amazon\">&nbsp;</span>\n                          Amazon\n                        </td>\n                        <td>\n                            $399.99\n                            <small>(May 27, 2022)</small>\n                        </td>\n                        <td>\n                            $499.99\n                            <small>(Jul 06, 2022)</small>\n                        </td>\n                        <td>\n                            -\n                        </td>\n                        <td>\n                            $449.24\n                        </td>\n                      </tr>\n                      <tr class=\"pt new \" data-field=\"new\">\n                        <td class=\"fixed nowrap new\">\n                          <span class=\"circle new\">&nbsp;</span>\n                          3rd Party New\n                        </td>\n                        <td>\n                            $194.00\n                            <small>(Jul 19, 2024)</small>\n                        </td>\n                        <td>\n                            $498.00\n                            <small>(Aug 16, 2022)</small>\n                        </td>\n                        <td>\n                            -\n                        </td>\n                        <td>\n                            $273.14\n                        </td>\n                      </tr>\n                      <tr class=\"pt used \" data-field=\"used\">\n                        <td class=\"fixed nowrap used\">\n                          <span class=\"circle used\">&nbsp;</span>\n                          3rd Party Used\n                        </td>\n                        <td>\n                            $154.99\n                            <small>(Jan 28, 2025)</small>\n                        </td>\n                        <td>\n                            $479.99\n                            <small>(Aug 18, 2022)</small>\n                        </td>\n                        <td>\n                            -\n                        </td>\n                        <td>\n                            $242.52\n                        </td>\n                      </tr>\n                  </tbody>\n                </table>\n              </div>\n              <!--/sse-->\n            </div>\n\n            <div class=\"cell\">\n              <p class=\"history-desc\">\n                camelcamelcamel monitors individual product prices across three Price Types: Amazon, Third Party New, and Third Party Used. \"Amazon\" means the price of an item Sold By and Shipped By Amazon itself; the two Third Party price types refer to third party prices on Amazon in New or Used condition, usually by marketplace sellers.\n              </p>\n            </div>\n\n            <div class=\"cell small-12 text-center\">\n              <div class=\"input-group shareform\" style=\"margin: 0 auto; max-width: 400px; color: black;\">\n                <span class=\"input-group-label\">Share:</span>\n                <input aria-label=\"Share:\" readonly=\"readonly\" type=\"text\" name=\"shareurl\" id=\"shareurl\" value=\"https://3cmls.co/US/B09QD75B95\" class=\"input-group-field\" style=\"font-size: 0.8rem;\">\n                <div class=\"input-group-button\">\n                  <button class=\"button blue-border\" id=\"sharebtn\" style=\"color: black; border: 1px solid #cacaca\" title=\"Copy Camel URL to clipboard\">\n                    <svg class=\"octicon octicon-copy\"><use href=\"#octicon-copy\"></use></svg>\n                  </button>\n                </div>\n              </div>\n            </div>\n        </div>\n      </div>\n      <!-- /price history section -->\n\n      <div class=\"cell\">\n        \n<div class=\"grid-x grid-x-margin ad\" data-adunit style=\"margin-bottom: 1rem;\">\n  <div class=\"cell\">\n    <div style=\"width: 100%;\">\n        <ins class=\"adsbygoogle\"\n            style=\"display:block\"\n            data-ad-client=\"ca-pub-2625650709713270\"\n            data-ad-slot=\"8558659632\"\n            data-ad-format=\"auto\"\n            data-full-width-responsive=\"true\"></ins>\n            <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>\n    </div>\n  </div>\n</div>\n\n      </div>\n\n      <!-- product details -->\n      <div class=\"cell\">\n        <h3 style=\"margin-top: 4rem;\">\n          Product Details\n        </h3>\n\n        \n<table class=\"product_fields\">\n  <tbody>\n    <tr class=\"odd\">\n    <td valign=\"middle\" nowrap=\"nowrap\" width=\"30.0%\">\n      <strong>Product group</strong>\n    </td>\n    <td valign=\"middle\" width=\"70.0%\" style=\"overflow-wrap: break-word;\">\n      Cam<wbr />era\n    </td>\n  <tr class=\"even\">\n    <td valign=\"middle\" nowrap=\"nowrap\" width=\"30.0%\">\n      <strong>Category</strong>\n    </td>\n    <td valign=\"middle\" width=\"70.0%\" style=\"overflow-wrap: break-word;\">\n      Elect<wbr />ronics\n    </td>\n  </tr>\n  <tr class=\"odd\">\n    <td valign=\"middle\" nowrap=\"nowrap\" width=\"30.0%\">\n      <strong>Manufacturer</strong>\n    </td>\n    <td valign=\"middle\" width=\"70.0%\" style=\"overflow-wrap: break-word;\">\n      GoPro <wbr />Camera\n    </td>\n  <tr class=\"even\">\n    <td valign=\"middle\" nowrap=\"nowrap\" width=\"30.0%\">\n      <strong>Model</strong>\n    </td>\n    <td valign=\"middle\" width=\"70.0%\" style=\"overflow-wrap: break-word;\">\n      CHDHX-<wbr />101-TH\n    </td>\n  </tr>\n  <tr class=\"odd\">\n    <td valign=\"middle\" nowrap=\"nowrap\" width=\"30.0%\">\n      <strong>Locale</strong>\n    </td>\n    <td valign=\"middle\" width=\"7