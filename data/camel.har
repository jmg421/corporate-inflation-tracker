            "text": "<form method=\"post\" action=\"/camels/new/B09QD75B95?locale=US\" id=\"pwform_B09QD75B95_US_1776950132\" class=\"pwform\" autocomplete=\"off\" data-asin=\"B09QD75B95\" data-locale=\"US\" data-domain=\"https://camelcamelcamel.com\" data-modal=\"\" data-id-suffix=\"US_B09QD75B95_0\">\n  <input type=\"hidden\" id=\"camelid\" name=\"camel\" value=\"\" />\n  <input type=\"hidden\" name=\"product_page_form\" value=\"1\">\n  <input type=\"hidden\" name=\"email_notify\" id=\"email\" value=\"1\">\n  <input type=\"hidden\" id=\"old_label\" name=\"existing_label\" value=\"\">\n\n    <input type=\"hidden\" name=\"new_label\" id=\"label\" value=\"\">\n\n\n  <input type=\"hidden\" name=\"locale\" value=\"US\">\n  <input type=\"hidden\" name=\"asin\" value=\"B09QD75B95\">\n\n\n\n  <div class=\"grid-x grid-margin-y\">\n    <h3>Set Your Desired Price</h3>\n\n    <div class=\"cell\">\n      <label for=\"pt\">\n        Price Type\n        <select name=\"type\" id=\"pt\">\n            <option value=\"price_amazon\" class=\"pt_price_amazon\">\n              Amazon\n            </option>\n            <option value=\"price_new\" class=\"pt_price_new\">\n              3rd Party New\n            </option>\n            <option value=\"price_used\" class=\"pt_price_used\">\n              3rd Party Used\n            </option>\n        </select>\n      </label>\n    </div>\n\n    <div class=\"cell\">\n        <div class=\"current-price\" id=\"cp_price_amazon\">\n          <p>\n            <span style=\"font-size: 0.8125rem; font-weight: bold;\">Current Amazon Price</span>\n            <br />\n            <span style=\"font-size: 1.25rem; font-weight: bold;\">\n                Not in Stock\n            </span>\n          </p>\n        </div>\n        <div class=\"current-price\" id=\"cp_price_new\">\n          <p>\n            <span style=\"font-size: 0.8125rem; font-weight: bold;\">Current 3rd Party New Price</span>\n            <br />\n            <span style=\"font-size: 1.25rem; font-weight: bold;\">\n                Not in Stock\n            </span>\n          </p>\n        </div>\n        <div class=\"current-price\" id=\"cp_price_used\">\n          <p>\n            <span style=\"font-size: 0.8125rem; font-weight: bold;\">Current 3rd Party Used Price</span>\n            <br />\n            <span style=\"font-size: 1.25rem; font-weight: bold;\">\n                Not in Stock\n            </span>\n          </p>\n        </div>\n    </div>\n    <div class=\"cell\">\n      <div class=\"separator\">&nbsp;</div>\n    </div>\n    <div class=\"cell\">\n      <label for=\"dp\">\n        Desired Price\n        <div class=\"input-group\">\n          <span class=\"input-group-label\">$</span>\n          <input type=\"text\" inputmode=\"decimal\" name=\"price\" id=\"dp\" class=\"input-group-field\" placeholder=\"Your desired price\"  data-autofocus />\n        </div>\n      </label>\n    </div>\n    <div class=\"cell\">\n\n        <div class=\"suggestions price_amazon\">\n            <p class=\"dplabel\">Shortcuts:</p>\n\n            <div class=\"grid-x exampledp\">\n    <div class=\"cell\">\n      <ul class=\"menu horizontal bubbled\">\n          <li>\n            <a href=\"#\" class=\"example_price_btn\" x-camel-price=\"436.49\" x-camel-id=\"price_amazon\" x-camel-label=\"-3%\">\n              -3%\n            </a>\n          </li>\n          <li>\n            <a href=\"#\" class=\"example_price_btn\" x-camel-price=\"427.49\" x-camel-id=\"price_amazon\" x-camel-label=\"-5%\">\n              -5%\n            </a>\n          </li>\n          <li>\n            <a href=\"#\" class=\"example_price_btn\" x-camel-price=\"418.49\" x-camel-id=\"price_amazon\" x-camel-label=\"-7%\">\n              -7%\n            </a>\n          </li>\n          <li>\n            <a href=\"#\" class=\"example_price_btn\" x-camel-price=\"404.99\" x-camel-id=\"price_amazon\" x-camel-label=\"-10%\">\n              -10%\n            </a>\n          </li>\n          <li>\n            <a href=\"#\" class=\"example_price_btn\" x-camel-price=\"449.98\" x-camel-id=\"price_amazon\" x-camel-label=\"Any Price Drop!\">\n              Any Price Drop!\n            </a>\n          </li>\n          <li>\n            <a href=\"#\" class=\"example_price_btn\" x-camel-price=\"419.99\" x-camel-id=\"price_amazon\" x-camel-label=\"Good Deal\">\n              Good Deal\n            </a>\n          </li>\n          <li>\n            <a href=\"#\" class=\"example_price_btn\" x-camel-price=\"399.99\" x-camel-id=\"price_amazon\" x-camel-label=\"Best Price\">\n              Best Price\n            </a>\n          </li>\n      </ul>\n    </div>\n  </div>\n\n        </div>\n\n        <div class=\"suggestions price_new\">\n            <p class=\"dplabel\">Shortcuts:</p>\n\n            <div class=\"grid-x exampledp\">\n    <div class=\"cell\">\n      <ul class=\"menu horizontal bubbled\">\n          <li>\n            <a href=\"#\" class=\"example_price_btn\" x-camel-price=\"232.80\" x-camel-id=\"price_new\" x-camel-label=\"-3%\">\n              -3%\n            </a>\n          </li>\n          <li>\n            <a href=\"#\" class=\"example_price_btn\" x-camel-price=\"228.00\" x-camel-id=\"price_new\" x-camel-label=\"-5%\">\n              -5%\n            </a>\n          </li>\n          <li>\n            <a href=\"#\" class=\"example_price_btn\" x-camel-price=\"223.20\" x-camel-id=\"price_new\" x-camel-label=\"-7%\">\n              -7%\n            </a>\n          </li>\n          <li>\n            <a href=\"#\" class=\"example_price_btn\" x-camel-price=\"216.00\" x-camel-id=\"price_new\" x-camel-label=\"-10%\">\n              -10%\n            </a>\n          </li>\n          <li>\n            <a href=\"#\" class=\"example_price_btn\" x-camel-price=\"239.99\" x-camel-id=\"price_new\" x-camel-label=\"Any Price Drop!\">\n              Any Price Drop!\n            </a>\n          </li>\n          <li>\n            <a href=\"#\" class=\"example_price_btn\" x-camel-price=\"203.70\" x-camel-id=\"price_new\" x-camel-label=\"Good Deal\">\n              Good Deal\n            </a>\n          </li>\n          <li>\n            <a href=\"#\" class=\"example_price_btn\" x-camel-price=\"194.00\" x-camel-id=\"price_new\" x-camel-label=\"Best Price\">\n              Best Price\n            </a>\n          </li>\n      </ul>\n    </div>\n  </div>\n\n        </div>\n\n        <div class=\"suggestions price_used\">\n            <p class=\"dplabel\">Shortcuts:</p>\n\n            <div class=\"grid-x exampledp\">\n    <div class=\"cell\">\n      <ul class=\"menu horizontal bubbled\">\n          <li>\n            <a href=\"#\" class=\"example_price_btn\" x-camel-price=\"253.15\" x-camel-id=\"price_used\" x-camel-label=\"-3%\">\n              -3%\n            </a>\n          </li>\n          <li>\n            <a href=\"#\" class=\"example_price_btn\" x-camel-price=\"247.93\" x-camel-id=\"price_used\" x-camel-label=\"-5%\">\n              -5%\n            </a>\n          </li>\n          <li>\n            <a href=\"#\" class=\"example_price_btn\" x-camel-price=\"242.71\" x-camel-id=\"price_used\" x-camel-label=\"-7%\">\n              -7%\n            </a>\n          </li>\n          <li>\n            <a href=\"#\" class=\"example_price_btn\" x-camel-price=\"234.88\" x-camel-id=\"price_used\" x-camel-label=\"-10%\">\n              -10%\n            </a>\n          </li>\n          <li>\n            <a href=\"#\" class=\"example_price_btn\" x-camel-price=\"260.97\" x-camel-id=\"price_used\" x-camel-label=\"Any Price Drop!\">\n              Any Price Drop!\n            </a>\n          </li>\n          <li>\n            <a href=\"#\" class=\"example_price_btn\" x-camel-price=\"162.74\" x-camel-id=\"price_used\" x-camel-label=\"Good Deal\">\n              Good Deal\n            </a>\n          </li>\n          <li>\n            <a href=\"#\" class=\"example_price_btn\" x-camel-price=\"154.99\" x-camel-id=\"price_used\" x-camel-label=\"Best Price\">\n              Best Price\n            </a>\n          </li>\n      </ul>\n    </div>\n  </div>\n\n        </div>\n    </div>\n    <div class=\"cell\">\n        <div class=\"email-section unregistered\">\n          <label for=\"email\">\n            Email Address\n            <input type=\"text\" name=\"email\" id=\"email\" placeholder=\"Your email address\" style=\"margin-top: 0.5rem;\" value=\"\">\n          </label>\n          <span>\n            We will notify you when the price drops!  <span id=\"reggo_spam\">(You can also <a href=\"/login?retailer=Amazon\" target=\"_blank\">log in</a> or <a href=\"/signup?retailer=Amazon\" target=\"_blank\">sign up</a>.)</span>\n          </span>\n        </div>\n    </div>\n    <div class=\"cell text-right\">\n        <a href=\"#\" class=\"button cancel hollow clear\">Cancel</a>\n      <input type=\"submit\" class=\"button primary-blue save\" value=\"Save\">\n    </div>\n  </div>\n</form>\n\n\n<script>\n\nchange_price_type($(\"#pt\").val());\n\n$(\"#pwform_B09QD75B95_US_1776950132 .example_price_btn\").on(\"click\", function(e){\n\n  var pf = $(this).attr(\"x-camel-id\");\n  var pc = $(this).attr(\"x-camel-price\");\n\n  $(\"#dp\").val(pc);\n  //$(\"#pwform_\" + pf).submit();\n  e.preventDefault();\n  camel_event(\"example_desired_price\", $(this).attr(\"x-camel-label\"), \"B09QD75B95\", \"US\");\n  return(false);\n});\n\n$(\"#pwform_B09QD75B95_US_1776950132 select\").on(\"change\", function() {\n  var price_field = $(this).val();\n  change_price_type(price_field);\n  camel_event(\"change_pw_price_type\", \"US\", \"B09QD75B95\", null);\n});\n\n$(\"#pwform_B09QD75B95_US_1776950132 .button.cancel\").on(\"click\", function(e) {\n    cancel_add_price_watch(e);\n  e.preventDefault();\n  camel_event(\"cancel_add_price_watch\", \"US\", \"B09QD75B95\", null);\n});\n\n$(\"#pwform_B09QD75B95_US_1776950132\").on(\"submit\", function(e) {\n  var dp = $(\"#dp\").val();\n  var form = $(this);\n  var submit = form.find(\"input[type='submit']\");\n  var field = $(\"#pt\").val();\n  var locale = form.attr(\"data-locale\");\n  var asin = form.attr(\"data-asin\");\n\n  if (!dp || dp == \"\")\n  {\n    //alert(\"Please enter a desired price.\");\n    $(\"#dp\").parent().addClass(\"animate__animated animate__shakeX\");\n    window.setTimeout(function() {\n      $(\"#dp\").parent().removeClass(\"animate__animated animate__shakeX\");\n    }, 500);\n\n    e.preventDefault();\n    return(false);\n  }\n\n/*\n  if (dp == $(\"#dp\").attr(\"data-orig\"))\n  {\n    //alert(\"Please change your desired price.\");\n    $(\"#dp\").parent().addClass(\"animate__animated animate__shakeX\"); // maybe unnecessary\n    window.setTimeout(function() {\n      $(\"#dp\").parent().removeClass(\"animate__animated animate__shakeX\");\n    }, 500);\n    e.preventDefault();\n    return(false);\n  }\n  */\n\n  if (!false && $(\"#email\").val() == \"\")\n  {\n    //alert(\"Please enter an email address.\");\n    $(\"#email\").addClass(\"animate__animated animate__shakeX\");\n    window.setTimeout(function() {\n      $(\"#email\").removeClass(\"animate__animated animate__shakeX\");\n    }, 500);\n    e.preventDefault();\n    return(false);\n  }\n\n  form.attr(\"disabled\", \"disabled\");\n\n  if (form.find(\"input[id='label']\").val() == \"\")\n    form.find(\"input[id='old_label']\").val(\"\");\n\n  //submit.attr(\"disabled\", \"disabled\");\n  //submit.addClass(\"disabled\");\n  //submit.addClass(\"loading\");\n\n  console.log(\"submitting\");\n\n\n  camel_event(\"save_price_watch\", \"US\", \"B09QD75B95\", null);\n});\n\n</script>\n"
