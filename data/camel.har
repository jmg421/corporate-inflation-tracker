<div style=\"position: relative;\">\n      <a name=\"watch\"><!-- // --></a>\n      <div id=\"pwcontent\"></div>\n    </div>\n  </div>\n  <div id=\"buy-box\" >\n    <div class=\"top\" style=\"position: relative;\">\n      <div style=\"position: absolute; top: 1rem; right: 1rem; \">\n        <a title=\"Show current prices for all price types.\" class=\"buy-box-toggler down \" href=\"#\"><svg class=\"octicon octicon-chevron-down\"><use href=\"#octicon-chevron-down\"></use></svg></a>\n        <a title=\"Hide other price types\" class=\"buy-box-toggler up hide\" href=\"#\"><svg class=\"octicon octicon-chevron-up\"><use href=\"#octicon-chevron-up\"></use></svg></a>\n      </div>\n      <div class=\"grid-x grid-margin-y\">\n              <div class=\"cell small-12  \">\n                <span class=\" bgp bgp\">Out of Stock</span>\n                <br />\n                <span class=\"price-type-label\">Amazon Price</span>\n              </div>\n              <div class=\"cell small-12 buy-box-togglee hide\">\n                <span class=\"smaller bgp bgp\">Out of Stock</span>\n                <br />\n                <span class=\"price-type-label\">3rd Party New Price</span>\n              </div>\n              <div class=\"cell small-12 buy-box-togglee hide\">\n                <span class=\"smaller bgp bgp\">Out of Stock</span>\n                <br />\n                <span class=\"price-type-label\">3rd Party Used Price</span>\n              </div>\n        <div class=\"cell small-12\">\n          <a href=\"https://camelcamelcamel.com/product/0LBT0O9AQGDG7Y5BB09D5/go?context=product&amp;ctx_pid=192721609&amp;ctx_cid=-1&amp;ctx_aid=-1&amp;ctx_act=buy&amp;ctx_src=buy-button&amp;\" target=\"_blank\" class=\"button expanded buy not-ugly\" x-camel-asin=\"B09QD75B95\" x-camel-locale=\"US\" x-camel-place=\"Product Page - Buy\" title=\"View this item's product page at Amazon\">\n            View at Amazon\n          </a>\n        </div>\n      </div>\n    </div>\n    <div class=\"bottom\">\n      \n<div id=\"existing-price-watches\">\n  <h3>Your Amazon Price Watches</h3>\n  <p style=\"font-size: 0.8125rem; color: #757575;\">\n    We'll notify you when the price drops to your desired price.\n  </p>\n  <div class=\"grid-x grid-margin-y\">\n  </div>\n</div>\n\n<a class=\"add-price-watch blue button expanded \" href=\"#\">\n  + Add Amazon Price Watch\n</a>\n\n\n<script>\nfunction load_add()\n{\n  var fields = [];\n    fields.push(\"price_amazon\");\n    fields.push(\"price_new\");\n    fields.push(\"price_used\");\n\n  $(\"#pwcontent\").load(\"htt\" + \"ps://camelcamelcamel.com/product/B09QD75B95/pwform\", {\n    \"asin\": \"B09QD75B95\",\n    \"locale\": \"US\",\n    \"mode\": null,\n    \"fields\": fields,\n    \"cancel_callback\": \"cancel_add_price_watch\",\n    \"save_callback\": \"\",\n    \"delete_callback\": \"\",\n    \"modal_id\": null,\n    \"camel\": null,\n    \"return_to\": window.location.pathname + window.location.search,\n    }, function(responseText, textStatus, jqXHR) {\n      pw_popup_overlay.hide();\n      $(\".price-watch-popup\").removeClass(\"loading\").addClass(\"loaded\");\n      if (jqXHR.status != 200) {\n        $(\"#pwcontent\").html(`Error loading price watch form. Please try again later.<br><br>(${jqXHR.status} ${jqXHR.statusText})`);\n      }\n      g_pw_preloaded = true;\n      recalc_sticky();\n    }\n  );\n}\n\nfor_onload(function() {\n  var overlay = new LoadingOverlay($(\"#buy-box\"));\n\n  $(\".alerted .octicon-bell\").addClass(\"animate__animated animate__tada animate__delay-1s\");\n  $(\".zero-click-form\").on(\"submit\", function(e) {\n    e.preventDefault();\n    var form = $(this);\n    overlay.show();\n\n    $.post({\n      url: form.attr(\"action\"),\n      data: form.serialize(),\n      success: function(d) {\n        $(\"#buy-box .bottom\").html(d).addClass(\"animate__animated animate__bounceIn\");\n\n        window.setTimeout(function() {\n          $(\"#buy-box .bottom\").removeClass(\"animate__animated animate__bounceIn\");\n        }, 1500);\n      },\n      error: function(d) {\n\n      },\n      complete: function(d) {\n        overlay.hide();\n      },\n    });\n  });\n\n  $(\".camel-rm-x\").on(\"click\", function(e) {\n    if (confirm(\"Are you sure you want to delete this price watch?\"))\n      $(this).closest(\"form\").submit();\n\n    e.preventDefault();\n  });\n\n  $(\".camel-edit-link\").on(\"click\", function(e) {\n    var camel_id = $(this).attr(\"data-camel-id\");\n    var field = $(this).attr(\"data-field\");\n\n    $(\"#pwcontent\").html(\"\");\n    $(\"#buy-box\").hide();\n    $(\"#phh3\").addClass(\"popped\");\n    $(\".price-watch-popup\").removeClass(\"loaded\").addClass(\"loading\");\n    $(\".price-watch-popup\").show();\n\n    pw_popup_overlay.show();\n    g_pw_preloaded = false;\n\n    $(\"#pwcontent\").load(\"htt\" + \"ps://camelcamelcamel.com/product/B09QD75B95/pwform\", {\n      \"asin\": \"B09QD75B95\",\n      \"locale\": \"US\",\n      \"mode\": null,\n      \"fields\": new Array(field),\n      \"cancel_callback\": \"cancel_add_price_watch\",\n      \"save_callback\": \"\",\n      \"delete_callback\": \"\",\n      \"modal_id\": null,\n      \"camel\": camel_id,\n      \"return_to\": window.location.pathname + window.location.search,\n      }, function(responseText, textStatus, jqXHR) {\n        pw_popup_overlay.hide();\n        $(\".price-watch-popup\").removeClass(\"loading\").addClass(\"loaded\");\n        if (jqXHR.status != 200) {\n          $(\"#pwcontent\").html(`Error loading price watch form. Please try again later.<br><br>(${jqXHR.status} ${jqXHR.statusText})`);\n        }\n        recalc_sticky();\n      }\n    );\n\n    goto_pwform();\n    e.preventDefault();\n    camel_event(\"edit_price_watch\", \"US\", \"B09QD75B95\", camel_id);\n  });\n\n  $(\".button.add-price-watch\").on(\"click\", function(e) {\n    if (!g_pw_preloaded)\n    {\n      $(\"#pwcontent\").html(\"\");\n      $(\".price-watch-popup\").addClass(\"loading\");\n    }\n\n    $(\"#buy-box\").hide();\n    $(\"#phh3\").addClass(\"popped\");\n    $(\".price-watch-popup\").show();\n    recalc_sticky();\n\n    if (!g_pw_preloaded)\n    {\n      pw_popup_overlay.show();\n      load_add();\n    }\n\n    goto_pwform();\n    e.preventDefault();\n    camel_event(\"add_price_watch\", \"US\", \"B09QD75B95\", null);\n  });\n});\n</script>\n\n    </div>\n  </div>\n</div>\n\n<script>\nfunction goto_pwform()\n{\n  if (Foundation.MediaQuery.atLeast('large'))\n    return;\n\n  $(\"html, body\").animate({\n    scrollTop: $(\"#buy-box-parent\").offset().top - 16\n  }, 250);\n}\n\nfunction cancel_add_price_watch(event)\n{\n  $(\".price-watch-popup\").hide();\n  $(\"#phh3\").removeClass(\"popped\");\n\n\n  $(\"#buy-box\").show();\n\n  if (event)\n    event.preventDefault();\n\n  recalc_sticky();\n\n  //$(\".button.add-price-watch\").show();\n  camel_event(\"cancel_add_price_watch\", \"US\", \"B09QD75B95\", null);\n}\n\nfunction recalc_sticky()\n{\n  try\n  {\n    //$$('.sticky').foundation('_calc', true);\n  }\n  catch (err)\n  {\n    //console.log(err);\n  }\n}\n\nvar g_pw_preloaded = false;\nvar pw_popup_overlay = null;\n\nfor_onload(function() {\n  pw_popup_overlay = new LoadingOverlay(\"#price-watch-popup\");\n  $(\".price-watch-popup .pwform\").data(\"x-overlay\", pw_popup_overlay);\n\n  $(\".buy-box-toggler\").on(\"click\", function(e) {\n    var up = $(this).hasClass(\"up\");\n    var down = $(this).hasClass(\"down\");\n\n    if (down)\n    {\n      $(\".buy-box-toggler.down\").addClass(\"hide\");\n      $(\".buy-box-toggler.up\").removeClass(\"hide\");\n      $(\".buy-box-togglee\").removeClass(\"hide\");\n    }\n    else\n    {\n      $(\".buy-box-toggler.up\").addClass(\"hide\");\n      $(\".buy-box-toggler.down\").removeClass(\"hide\");\n      $(\".buy-box-togglee\").addClass(\"hide\");\n    }\n\n    var exdate=new Date();\n    exdate.setDate(exdate.getDate() + (1000));\n    var c_value = escape(down ? \"down\" : \"up\") + \"; expires=\"+exdate.toUTCString() + \"; path=/; domain=camelcamelcamel.com; secure; samesite=strict\";\n    document.cookie='bbtoggle' + \"=\" + c_value;\n\n    recalc_sticky();\n    e.preventDefault();\n    camel_event(\"toggle_buy_box\", \"US\", \"B09QD75B95\", null);\n  });\n\n  load_add();\n});\n</script>\n\n  <!-- /buy box -->\n</div>\n\n<div class=\"grid-x\">\n  <!-- highlights -->\n  <div class=\"cell\">\n    <h3 style=\"margin-top: 4rem;\">\n      <a href=\"/highlights?bn=electronics\" class=\"view-all\">Highlighted Deals</a>\n    </h3>\n\n    \n\n  <div id=\"parent_ptable_27c96d829b378dc738f008114a74d812\" class=\"ptable carousel_parent not-ugly\">\n    <div id=\"ptable_27c96d829b378dc738f008114a74d812\" class=\"carousel not-ugly\" >\n        <div class=\"slide\">\n          <div class=\"product-card\">\n            <div class=\"grid-x grid-margin-x\">\n              <!-- thumb -->\n              <div class=\"cell \">\n                <div class=\"product_thumb\">\n                    <div class=\"camelbadge good_deal\">\n                        Good Deal\n                    </div>\n\n\n                  <a href=\"https://camelcamelcamel.com/product/B0CB76X1MG?active=price_amazon&amp;context=sp\" title=\"Price history for Wyze Offical: Window Mount for Wyze Cam OG, v3, v3 Pro, v4\" href=\"https://camelcamelcamel.com/product/B0CB76X1MG?active=price_amazon&amp;context=sp\">\n                    <div class=\"thumbph\">\n                        <img id=\"img_052166_0\" alt=\"Wyze Offical: Window Mount for Wyze Cam OG, v3, v3 Pro, v4 (B0CB76X1MG) Amazon Price History, Amazon Price Tracking\" src=\"https://m.media-amazon.com/images/I/210RHG7WkzL._UL300_.jpg\" fetchpriority=\"high\" class=\"badged\">\n                    </div>\n                  </a>\n                </div>\n              </div>\n              <!-- // thumb -->\n\n              <!-- product info -->\n              <div class=\"cell text-center\">\n                <div class=\"product-info\">\